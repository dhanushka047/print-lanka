# ============================================================
# IO Builds — VPS / self-hosted environment template
# Copy to `.env` on the VPS and fill in values from your
# self-hosted Supabase install.
# ============================================================

# Public URL of your self-hosted Supabase (Kong gateway).
# This is what the browser will hit for REST / Auth / Storage / Functions.
VITE_SUPABASE_URL=https://db.3dprint.iobuilds.com

# Anon (publishable) JWT — generated when you set up self-hosted Supabase.
# See: https://supabase.com/docs/guides/self-hosting/docker#generate-api-keys
VITE_SUPABASE_PUBLISHABLE_KEY=replace-with-your-anon-key

# Free-form project identifier (used only in a couple of UI labels).
VITE_SUPABASE_PROJECT_ID=self-hosted
